{
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "GET_FROM_VAULT: GITHUB_TOKEN"
      }
    },
    "cloudflare": {
      "command": "npx",
      "args": ["-y", "@cloudflare/mcp-server-cloudflare"],
      "env": {
        "CLOUDFLARE_API_TOKEN": "GET_FROM_VAULT: CF_API_TOKEN",
        "CLOUDFLARE_ACCOUNT_ID": "a6f47c17811ee2f8b6caeb8f38768c20"
      }
    }
  },
  "_setup_note": "Replace GET_FROM_VAULT values with: curl -s -H 'X-Pin: 535554' https://asgard-vault.pgallivan.workers.dev/secret/GITHUB_TOKEN"
}
